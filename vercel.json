{
  "version": 2,
  "crons": [
    {
      "path": "/api/weekly-digest",
      "schedule": "0 10 * * 1"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "headers": { "Cache-Control": "public, max-age=3600" },
      "dest": "/$1"
    }
  ]
}
